FROM python:3.10-slim
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
ENV PYTHONUSERBASE=/home/appuser/.local
ENV PATH="/home/appuser/.local/bin:${PATH}"
ENV PYTHONPATH="/home/appuser/.local/lib/python3.10/site-packages"
RUN useradd -m appuser && mkdir /app && chown appuser:appuser /app
WORKDIR /app
RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir fastapi uvicorn jupyter_client ipykernel matplotlib pandas psutil
COPY --chown=appuser:appuser exe_kernel.py /app/exe_kernel.py
EXPOSE 8000
CMD ["uvicorn", "exe_kernel:app", "--host", "0.0.0.0", "--port", "8000"]